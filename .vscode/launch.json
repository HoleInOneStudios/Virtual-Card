{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:3000/docs/index.html",
            "webRoot": "${workspaceFolder}/docs"
        },
        {
            "name": "Launch Chrome with params",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:3000/docs/index.html?to=Mom&from=Ben&occasion=Mothers+Day&note=I+love+you.&color=%23ffffff&encrypt=false",
            "webRoot": "${workspaceFolder}/docs"
        },
        {
            "name": "Launch Chrome with params and encrypted",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:3000/docs/index.html?message=&encrypt=true",
            "webRoot": "${workspaceFolder}/docs"
        }
    ]
}